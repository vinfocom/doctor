  old_slot_time String?   @db.VarChar(5)
  old_status    String?   @db.VarChar(20)
  new_status    String?   @db.VarChar(20)
  status        String    @default("PENDING") @db.VarChar(20)
  lock_owner    String?   @db.VarChar(80)
  locked_at     DateTime? @db.DateTime(0)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @db.Timestamp(0)

  @@index([clinic_id], map: "idx_dcq_clinic")
  @@index([doctor_id], map: "idx_dcq_doc")
  @@index([status, queue_id], map: "idx_dcq_poll")
}

model message_delivery_status {
  delivery_id          BigInt   @id @default(autoincrement())
  provider             String   @db.VarChar(30)
  provider_message_sid String   @db.VarChar(100)
  channel              String   @db.VarChar(30)
  message_status       String   @db.VarChar(40)
  to_number            String?  @db.VarChar(120)
  from_number          String?  @db.VarChar(120)
  error_code           String?  @db.VarChar(40)
  error_message        String?  @db.Text
  payload_json         String?  @db.Text
  created_at           DateTime @default(now()) @db.Timestamp(0)
  updated_at           DateTime @default(now()) @db.Timestamp(0)
  channel_account_id   BigInt?
  doctor_id            Int?
  admin_id             Int?

  @@unique([provider, provider_message_sid], map: "uq_provider_sid")
  @@index([message_status, updated_at], map: "idx_delivery_status")
  @@index([channel_account_id], map: "idx_delivery_status_channel_account")
  @@index([doctor_id], map: "idx_delivery_status_doctor")
  @@index([admin_id], map: "idx_delivery_status_admin")
}

model qr_walkin_queue {
  queue_id       BigInt    @id @default(autoincrement())
  admin_id       BigInt
  doctor_id      BigInt
  clinic_id      BigInt
  patient_name   String    @db.VarChar(255)
  phone          String    @db.VarChar(32)
  queue_date     DateTime  @db.Date
  queue_position Int
  estimated_time DateTime? @db.DateTime(0)
  status         String    @default("WAITING") @db.VarChar(20)
  source_channel String    @default("qr") @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @db.Timestamp(0)

  @@unique([doctor_id, clinic_id, queue_date, phone, status], map: "uq_qr_waiting_phone")
  @@index([doctor_id, clinic_id, queue_date, status, queue_position], map: "idx_qr_waiting_lookup")
}

model clinic_staff {
  staff_id         Int                          @id @default(autoincrement())
  doctor_id        Int
  clinic_id        Int?
  user_id          Int                          @unique
  whatsapp_number  String?                      @db.VarChar(255)
  staff_role       String                       @db.VarChar(20)
  status           String                       @default("ACTIVE") @db.VarChar(20)
  valid_from       DateTime?                    @db.Date
  valid_to         DateTime?                    @db.Date
  created_at       DateTime                     @default(now()) @db.Timestamp(0)
  doctors          doctors                      @relation(fields: [doctor_id], references: [doctor_id])
  users            users                        @relation(fields: [user_id], references: [user_id])
  clinics          clinics?                     @relation(fields: [clinic_id], references: [clinic_id])
  doctor_access    clinic_staff_doctor_access[]

  @@index([clinic_id], map: "clinic_staff_clinic_id_fkey")
  @@index([doctor_id], map: "clinic_staff_doctor_id_fkey")
}

model clinic_staff_doctor_access {
  access_id   Int          @id @default(autoincrement())
  staff_id    Int
  doctor_id   Int
  created_at  DateTime     @default(now()) @db.Timestamp(0)

  staff       clinic_staff @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)
  doctor      doctors      @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade)

  @@unique([staff_id, doctor_id], map: "uq_staff_doctor_access")
  @@index([staff_id], map: "idx_staff_doctor_access_staff")
  @@index([doctor_id], map: "idx_staff_doctor_access_doctor")
}

model live_queue_side_ads {
  ad_id        Int                       @id @default(autoincrement())
  doctor_id    Int
  clinic_id    Int
  position     QueueSideAdPosition
  type         QueueSideAdType
  asset_url    String                    @db.VarChar(1000)
  mime_type    String?                   @db.VarChar(255)
  title        String?                   @db.VarChar(255)
  is_active    Boolean                   @default(true)
  active_from  DateTime?                 @db.Date
  active_to    DateTime?                 @db.Date
  sort_order   Int                       @default(0)
  created_at   DateTime                  @default(now()) @db.Timestamp(0)
  updated_at   DateTime                  @default(now()) @updatedAt @db.Timestamp(0)
  clinic       clinics                   @relation(fields: [clinic_id], references: [clinic_id], onDelete: Cascade)
  doctor       doctors                   @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade)

  @@index([doctor_id, clinic_id, position, is_active], map: "idx_live_queue_side_ads_lookup")
  @@index([clinic_id], map: "live_queue_side_ads_clinic_id_fkey")
  @@index([doctor_id], map: "live_queue_side_ads_doctor_id_fkey")
}

model live_queue_display_settings {
  setting_id                Int      @id @default(autoincrement())
  hospital_group_code       String   @unique(map: "uq_live_queue_display_hospital_group") @db.VarChar(191)
  remaining_slide_seconds   Int      @default(8)
  missed_slide_seconds      Int      @default(8)
  doctor_rotation_seconds   Int      @default(40)
  updated_by_doctor_id      Int?
  created_at                DateTime @default(now()) @db.Timestamp(0)
  updated_at                DateTime @default(now()) @updatedAt @db.Timestamp(0)
  updated_by_doctor         doctors? @relation(fields: [updated_by_doctor_id], references: [doctor_id], onDelete: SetNull)

  @@index([updated_by_doctor_id], map: "idx_live_queue_display_updated_by_doctor")
}

