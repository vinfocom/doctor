generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model doctor_remainder_queue {
  queue_id            Int                     @id @default(autoincrement())
  doctor_id           Int
  schedule_id         Int?
  admin_id            Int?
  slot_date           DateTime                @db.Date
  schedule_start_time DateTime?               @db.Time(0)
  schedule_end_time   DateTime?               @db.Time(0)
  channel             String?                 @db.VarChar(50)
  destination         String?                 @db.VarChar(255)
  status              String?                 @db.VarChar(50)
  attempt_count       Int                     @default(0)
  next_retry_at       DateTime?
  last_error          String?                 @db.VarChar(255)
  dedup_key           String?                 @unique @db.VarChar(255)
  created_at          DateTime                @default(now()) @db.Timestamp(0)
  updated_at          DateTime                @updatedAt @db.Timestamp(0)
  sent_at             DateTime?               @db.Timestamp(0)
  lead_minutes        Int                     @default(10)
  admin               admins?                 @relation(fields: [admin_id], references: [admin_id])
  doctor              doctors                 @relation(fields: [doctor_id], references: [doctor_id])
  schedule            doctor_clinic_schedule? @relation(fields: [schedule_id], references: [schedule_id])

  @@index([doctor_id, slot_date])
  @@index([admin_id], map: "doctor_remainder_queue_admin_id_fkey")
  @@index([schedule_id], map: "doctor_remainder_queue_schedule_id_fkey")
}

model users {
  user_id      Int           @id @default(autoincrement())
  name         String?       @db.VarChar(255)
  email        String?       @unique @db.VarChar(255)
  password     String?       @db.VarChar(255)
  role         users_role
  created_at   DateTime?     @default(now()) @db.Timestamp(0)
  admin        admins?
  clinic_staff clinic_staff?
  doctor       doctors?
  password_reset_otps user_password_otps[]
  user_tokens  user_tokens[]
  uploaded_prescriptions prescription_records[] @relation("prescription_uploaded_by_user")
  emr_deleted_prescriptions prescriptions[] @relation("emr_prescription_deleted_by")
  reviewed_emr_master_logs  prescription_master_review_logs[]
}

model admins {
  admin_id              Int                      @id @default(autoincrement())
  user_id               Int?                     @unique
  created_at            DateTime?                @default(now()) @db.Timestamp(0)
  user                  users?                   @relation(fields: [user_id], references: [user_id])
  appointments          appointment[]
  clinics               clinics[]
  schedules             doctor_clinic_schedule[]
  leaves                doctor_leaves[]
  doctorRemainderQueues doctor_remainder_queue[]
  doctors               doctors[]
  patients              patients[]
}

model channel_accounts {
  channel_account_id  BigInt   @id @default(autoincrement())
  admin_id            Int?
  channel             String   @db.VarChar(30)
  provider            String   @db.VarChar(30)
  account_label       String?  @db.VarChar(120)
  sender_identity     String   @db.VarChar(191)
  webhook_path_key    String?  @unique(map: "uq_channel_webhook_key") @db.VarChar(120)
  webhook_secret_enc  String?  @db.Text
  credential_json_enc String?  @db.LongText
  status              String   @default("ACTIVE") @db.VarChar(20)
  is_primary          Boolean  @default(false)
  created_at          DateTime @default(now()) @db.Timestamp(0)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([channel, provider, sender_identity], map: "uq_channel_provider_sender")
  @@index([admin_id], map: "idx_channel_accounts_admin")
  @@index([status], map: "idx_channel_accounts_status")
}

model doctors {
  doctor_id              Int                       @id @default(autoincrement())
  doctor_name            String?                   @db.VarChar(255)
  phone                  String?                   @db.VarChar(255)
  status                 DoctorStatus?
  admin_id               Int
  user_id                Int?                      @unique
  whatsapp_number        String?                   @db.VarChar(255)
  specialization         String?                   @db.VarChar(255)
  acceptDays             Int?
  chat_id                BigInt?                   @unique
  telegram_userid        String?                   @db.VarChar(255)
  username               String?                   @db.VarChar(255)
  gst_number             String?                   @db.VarChar(255)
  pan_number             String?                   @db.VarChar(255)
  address                String?                   @db.VarChar(500)
  registration_no        String?                   @db.VarChar(255)
  education              String?                   @db.VarChar(500)
  document_url           String?                   @db.VarChar(500)
  profile_pic_url        String?                   @db.VarChar(500)
  push_token             String?                   @db.VarChar(255)
  active_from            DateTime?                 @db.Date
  active_to              DateTime?                 @db.Date
  num_clinics            Int?                      @default(0)
  slug                   String?                   @unique(map: "slug") @db.VarChar(255)
  announcement_campaigns announcement_campaigns[]
  appointments           appointment[]
  chat_messages          chat_messages[]
  clinic_staff           clinic_staff[]
  clinic_staff_access    clinic_staff_doctor_access[]
  clinics                clinics[]
  schedules              doctor_clinic_schedule[]
  leaves                 doctor_leaves[]
  doctorRemainderQueues  doctor_remainder_queue[]
  liveQueueAds           live_queue_side_ads[]
  liveQueueDisplaySettings live_queue_display_settings[]
  sms_service            doctor_sms_service?
  sms_recharge_logs      doctor_sms_recharge_log[]
  sms_usage_logs         doctor_sms_usage_log[]
  whatsapp_numbers       doctor_whatsapp_numbers[]
  admin                  admins                    @relation(fields: [admin_id], references: [admin_id])
  user                   users?                    @relation(fields: [user_id], references: [user_id])
  patients               patients[]
  prescriptions          prescription_records[] @relation("prescription_record_doctor")
  emr_settings           doctor_emr_settings?
  emr_prescriptions      prescriptions[] @relation("emr_prescription_doctor")
  medicines_master       medicines_master[] @relation("emr_medicines_master_created_by")
  complaints_master      complaints_master[] @relation("emr_complaints_master_created_by")
  diagnosis_master       diagnosis_master[] @relation("emr_diagnosis_master_created_by")
  tests_master           tests_master[] @relation("emr_tests_master_created_by")
  advice_master          advice_master[] @relation("emr_advice_master_created_by")
  prescription_audit_logs prescription_audit_logs[] @relation("emr_prescription_audit_doctor")
  prescription_layout_settings prescription_layout_settings[]

  @@index([admin_id], map: "doctors_admin_id_fkey")
}

model doctor_whatsapp_numbers {
  id              Int      @id @default(autoincrement())
  doctor_id       Int
  whatsapp_number String   @db.VarChar(255)
  is_primary      Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  chat_id         BigInt?
  username        String?  @db.VarChar(255)
  doctor          doctors  @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade)

  @@index([doctor_id], map: "doctor_whatsapp_numbers_doctor_id_fkey")
}

model doctor_channel_bindings {
  binding_id          BigInt   @id @default(autoincrement())
  doctor_id           Int
  clinic_id           Int?
  channel_account_id  BigInt
  status              String   @default("ACTIVE") @db.VarChar(20)
  is_primary          Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamp(0)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([doctor_id, clinic_id, channel_account_id], map: "uq_doctor_clinic_account")
  @@index([doctor_id], map: "idx_dcb_doctor")
  @@index([clinic_id], map: "idx_dcb_clinic")
  @@index([channel_account_id], map: "idx_dcb_channel_account")
  @@index([doctor_id, clinic_id, is_primary, status], map: "idx_dcb_primary")
}

model doctor_sms_service {
  id                  Int                @id @default(autoincrement())
  doctor_id           Int                @unique
  sms_service_enabled Boolean            @default(false)
  sms_service_status  SmsServiceStatus   @default(DISABLED)
  sms_credit_total    Int                @default(0)
  sms_credit_used     Int                @default(0)
  current_pack_total  Int                @default(0)
  current_pack_used   Int                @default(0)
  last_recharged_at   DateTime?          @db.Timestamp(0)
  low_pack_alert_sent_at DateTime?       @db.Timestamp(0)
  exhausted_alert_sent_at DateTime?      @db.Timestamp(0)
  created_at          DateTime           @default(now()) @db.Timestamp(0)
  updated_at          DateTime           @default(now()) @updatedAt @db.Timestamp(0)
  doctor              doctors            @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade)

  @@index([sms_service_status], map: "idx_doctor_sms_service_status")
}

model doctor_sms_recharge_log {
  id             Int       @id @default(autoincrement())
  doctor_id      Int
  credits_added  Int
  previous_total Int
  new_total      Int
  remarks        String?   @db.VarChar(255)
  recharged_by   Int?
  created_at     DateTime  @default(now()) @db.Timestamp(0)
  doctor         doctors   @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade)

  @@index([doctor_id, created_at], map: "idx_doctor_sms_recharge_log_lookup")
}

model doctor_evolution_bindings {
  binding_id                  BigInt   @id @default(autoincrement())
  doctor_id                   Int
  clinic_id                   Int?
  evolution_instance_name     String   @unique(map: "uq_doctor_evolution_instance") @db.VarChar(191)
  evolution_account_identity  String?  @unique(map: "uq_doctor_evolution_account") @db.VarChar(64)
  status                      String   @default("ACTIVE") @db.VarChar(20)
  created_at                  DateTime @default(now()) @db.Timestamp(0)
  updated_at                  DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@index([doctor_id], map: "idx_doctor_evolution_doctor")
  @@index([status], map: "idx_doctor_evolution_status")
}

model doctor_sms_usage_log {
  id            Int      @id @default(autoincrement())
  doctor_id     Int
  appointment_id Int
  credits_used  Int      @default(1)
  created_at    DateTime @default(now()) @db.Timestamp(0)
  doctor        doctors  @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade)

  @@unique([appointment_id], map: "uq_doctor_sms_usage_appointment")
  @@index([doctor_id, created_at], map: "idx_doctor_sms_usage_lookup")
}

model clinics {
  clinic_id                    Int                               @id @default(autoincrement())
  clinic_name                  String?                           @db.VarChar(255)
  phone                        String?                           @db.VarChar(255)
  status                       ClinicStatus?
  admin_id                     Int
  doctor_id                    Int?
  location                     String?                           @db.VarChar(255)
  barcode_url                  String?                           @db.VarChar(500)
  qr_storage_url               String?                           @db.VarChar(500)
  hospital_group_code          String?                           @db.VarChar(191)
  created_at                   DateTime?                         @default(now()) @db.Timestamp(0)
  appointments                 appointment[]
  admin                        admins                            @relation(fields: [admin_id], references: [admin_id])
  doctor                       doctors?                          @relation(fields: [doctor_id], references: [doctor_id])
  liveQueueAds                 live_queue_side_ads[]
  prescriptions                prescription_records[]            @relation("prescription_record_clinic")
  emr_prescriptions            prescriptions[]                   @relation("emr_prescription_clinic")
  prescription_layout_settings prescription_layout_settings[]
  schedules                    doctor_clinic_schedule[]
  clinic_staff                 clinic_staff[]

  @@index([admin_id], map: "clinics_admin_id_fkey")
  @@index([doctor_id], map: "clinics_doctor_id_fkey")
  @@index([hospital_group_code], map: "idx_clinics_hospital_group_code")
}

model patients {
  patient_id              Int                                @id @default(autoincrement())
  full_name               String?                            @db.VarChar(255)
  admin_id                Int
  doctor_id               Int?
  profile_type            PatientProfileType                 @default(SELF)
  status                  PatientStatus?
  phone                   String?                            @db.VarChar(255)
  booking_id              Int?
  telegram_chat_id        String?                            @unique @db.VarChar(255)
  patient_count           Int?                               @default(0)
  age                     Int?
  gender                  String?                            @db.VarChar(20)
  password                String?                            @db.VarChar(255)
  push_token              String?                            @db.VarChar(255)
  announcement_recipients announcement_campaign_recipients[]
  appointments            appointment[]
  chat_messages           chat_messages[]
  password_otps           patient_password_otps[]
  prescriptions           prescription_records[] @relation("prescription_record_patient")
  uploaded_prescriptions  prescription_records[] @relation("prescription_uploaded_by_patient")
  emr_prescriptions       prescriptions[] @relation("emr_prescription_patient")
  emr_prescription_audit_logs prescription_audit_logs[] @relation("emr_prescription_audit_patient")
  whatsapp_numbers        patient_whatsapp_numbers[]
  admin                   admins                             @relation(fields: [admin_id], references: [admin_id])
  doctor                  doctors?                           @relation(fields: [doctor_id], references: [doctor_id])

  @@index([admin_id], map: "patients_admin_id_fkey")
  @@index([doctor_id], map: "patients_doctor_id_fkey")
  @@index([admin_id, phone, profile_type], map: "idx_patients_admin_phone_profile_type")
}

model inbound_turn_queue {
  queue_id      BigInt    @id @default(autoincrement())
  inbound_sid   String    @unique(map: "uq_inbound_turn_sid") @db.VarChar(96)
  from_number   String    @db.VarChar(80)
  body          String    @db.Text
  pre_state     String    @db.VarChar(64)
  status        String    @default("PENDING") @db.VarChar(20)
  attempt_count Int       @default(0)
  next_retry_at DateTime? @db.DateTime(0)
  locked_at     DateTime? @db.DateTime(0)
  lock_owner    String?   @db.VarChar(80)
  last_error    String?   @db.Text
  dead_at       DateTime? @db.DateTime(0)
  dead_reason   String?   @db.Text
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @db.Timestamp(0)
  channel_account_id BigInt?
  source_channel String?   @db.VarChar(30)

  @@index([status, next_retry_at], map: "idx_inbound_turn_poll")
  @@index([locked_at, lock_owner], map: "idx_inbound_turn_lock")
  @@index([channel_account_id], map: "idx_inbound_turn_channel_account")
}

model patient_whatsapp_numbers {
  id              Int      @id @default(autoincrement())
  patient_id      Int
  whatsapp_number String   @db.VarChar(255)
  is_primary      Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  chat_id         BigInt?
  username        String?  @db.VarChar(255)
  patient         patients @relation(fields: [patient_id], references: [patient_id], onDelete: Cascade)

  @@index([patient_id], map: "patient_whatsapp_numbers_patient_id_fkey")
}

model patient_password_otps {
  otp_id                   Int                        @id @default(autoincrement())
  patient_id               Int
  phone                    String                     @db.VarChar(20)
  purpose                  patient_password_otp_purpose
  otp_hash                 String                     @db.VarChar(255)
  expires_at               DateTime                   @db.DateTime(0)
  resend_after             DateTime?                  @db.DateTime(0)
  used_at                  DateTime?                  @db.DateTime(0)
  attempt_count            Int                        @default(0)
  resend_count             Int                        @default(0)
  verification_token       String?                    @db.VarChar(255)
  verification_expires_at  DateTime?                  @db.DateTime(0)
  created_at               DateTime                   @default(now()) @db.Timestamp(0)
  updated_at               DateTime                   @default(now()) @db.Timestamp(0)
  patient                  patients                   @relation(fields: [patient_id], references: [patient_id], onDelete: Cascade)

  @@index([patient_id], map: "patient_password_otps_patient_id_fkey")
  @@index([phone, purpose, created_at], map: "idx_patient_password_otps_phone_purpose_created")
  @@index([phone, purpose, used_at, expires_at], map: "idx_patient_password_otps_phone_purpose_active")
}

model doctor_signup_otps {
  otp_id                   Int                       @id @default(autoincrement())
  channel                  doctor_signup_otp_channel
  target                   String                    @db.VarChar(255)
  otp_hash                 String                    @db.VarChar(255)
  attempt_count            Int                       @default(0)
  resend_count             Int                       @default(0)
  expires_at               DateTime                  @db.DateTime(0)
  resend_after             DateTime?                 @db.DateTime(0)
  verified_at              DateTime?                 @db.DateTime(0)
  verification_token       String?                   @db.VarChar(255)
  verification_expires_at  DateTime?                 @db.DateTime(0)
  used_at                  DateTime?                 @db.DateTime(0)
  created_at               DateTime                  @default(now()) @db.Timestamp(0)
  updated_at               DateTime                  @default(now()) @updatedAt @db.Timestamp(0)

  @@index([target, channel, created_at], map: "idx_doctor_signup_otps_target_channel_created")
  @@index([target, channel, used_at, expires_at], map: "idx_doctor_signup_otps_target_channel_active")
  @@index([verification_token], map: "idx_doctor_signup_otps_verification_token")
}

model user_password_otps {
  otp_id                   Int                       @id @default(autoincrement())
  user_id                  Int
  email                    String                    @db.VarChar(255)
  purpose                  user_password_otp_purpose @default(RESET_PASSWORD)
  otp_hash                 String                    @db.VarChar(255)
  attempt_count            Int                       @default(0)
  expires_at               DateTime                  @db.DateTime(0)
  resend_after             DateTime                  @db.DateTime(0)
  verification_token       String?                   @db.VarChar(255)
  verification_expires_at  DateTime?                 @db.DateTime(0)
  verified_at              DateTime?                 @db.DateTime(0)
  used_at                  DateTime?                 @db.DateTime(0)
  created_at               DateTime                  @default(now()) @db.Timestamp(0)
  updated_at               DateTime                  @default(now()) @updatedAt @db.Timestamp(0)
  user                     users                     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade, map: "fk_user_password_otps_user")

  @@index([user_id], map: "idx_user_password_otps_user_id")
  @@index([email, purpose, created_at], map: "idx_user_password_otps_email_purpose_created")
  @@index([email, purpose, used_at, expires_at], map: "idx_user_password_otps_email_purpose_active")
}

model appointment {
  appointment_id              Int                            @id @default(autoincrement())
  patient_id                  Int?
  doctor_id                   Int?
  clinic_id                   Int?
  admin_id                    Int?
  status                      AppointmentStatus?
  booked_for                  String?                        @db.VarChar(10)
  channel                     AppointmentChannel?
  created_at                  DateTime?                      @default(now()) @db.Timestamp(0)
  start_time                  DateTime?                      @db.Time(0)
  end_time                    DateTime?                      @db.Time(0)
  appointment_date            DateTime?                      @db.Date
  booking_id                  Int?
  cancelled_by                String?                        @db.VarChar(255)
  rescheduled_by              String?                        @db.VarChar(255)
  notify_telegram_chat_id     BigInt?
  admin                       admins?                        @relation(fields: [admin_id], references: [admin_id])
  clinic                      clinics?                       @relation(fields: [clinic_id], references: [clinic_id])
  doctor                      doctors?                       @relation(fields: [doctor_id], references: [doctor_id])
  patient                     patients?                      @relation(fields: [patient_id], references: [patient_id])
  appointmentNotificationLogs appointment_notification_log[]
  prescriptions               prescription_records[] @relation("prescription_record_appointment")
  emr_prescriptions           prescriptions[] @relation("emr_prescription_appointment")

  @@unique([doctor_id, appointment_date, start_time])
  @@index([appointment_date])
  @@index([admin_id], map: "appointment_admin_id_fkey")
  @@index([clinic_id], map: "appointment_clinic_id_fkey")
  @@index([patient_id], map: "appointment_patient_id_fkey")
}

model prescription_records {
  prescription_id         Int                      @id @default(autoincrement())
  patient_id              Int
  doctor_id               Int
  clinic_id               Int?
  appointment_id          Int?
  uploaded_by_role        PrescriptionUploadRole
  uploaded_by_user_id     Int?
  uploaded_by_patient_id  Int?
  note                    String?                  @db.VarChar(500)
  page_count              Int                      @default(1)
  status                  PrescriptionRecordStatus @default(ACTIVE)
  created_at              DateTime                 @default(now()) @db.Timestamp(0)
  updated_at              DateTime                 @default(now()) @updatedAt @db.Timestamp(0)
  patient                 patients                 @relation("prescription_record_patient", fields: [patient_id], references: [patient_id], onDelete: Cascade)
  doctor                  doctors                  @relation("prescription_record_doctor", fields: [doctor_id], references: [doctor_id], onDelete: Cascade)
  clinic                  clinics?                 @relation("prescription_record_clinic", fields: [clinic_id], references: [clinic_id], onDelete: SetNull)
  appointment             appointment?             @relation("prescription_record_appointment", fields: [appointment_id], references: [appointment_id], onDelete: SetNull)
  uploaded_by_user        users?                   @relation("prescription_uploaded_by_user", fields: [uploaded_by_user_id], references: [user_id], onDelete: SetNull)
  uploaded_by_patient     patients?                @relation("prescription_uploaded_by_patient", fields: [uploaded_by_patient_id], references: [patient_id], onDelete: SetNull)
  pages                   prescription_pages[]

  @@index([patient_id, doctor_id, created_at], map: "idx_prescription_patient_doctor_created")
  @@index([doctor_id, created_at], map: "idx_prescription_doctor_created")
  @@index([appointment_id], map: "idx_prescription_appointment")
  @@index([clinic_id], map: "idx_prescription_clinic")
  @@index([uploaded_by_user_id], map: "idx_prescription_uploaded_by_user")
  @@index([uploaded_by_patient_id], map: "idx_prescription_uploaded_by_patient")
}

model prescription_pages {
  prescription_page_id Int                   @id @default(autoincrement())
  prescription_id      Int
  page_number          Int
  storage_key          String                @db.VarChar(1000)
  file_url             String                @db.VarChar(1000)
  mime_type            String?               @db.VarChar(100)
  original_file_name   String?               @db.VarChar(255)
  file_size_bytes      Int?
  width                Int?
  height               Int?
  created_at           DateTime              @default(now()) @db.Timestamp(0)
  prescription         prescription_records  @relation(fields: [prescription_id], references: [prescription_id], onDelete: Cascade)

  @@unique([prescription_id, page_number], map: "uq_prescription_page_number")
  @@index([prescription_id], map: "idx_prescription_pages_prescription")
}

model doctor_emr_settings {
  id                        Int      @id @default(autoincrement())
  doctor_id                 Int      @unique
  emr_prescription_enabled  Boolean  @default(false)
  created_at                DateTime @default(now()) @db.Timestamp(0)
  updated_at                DateTime @default(now()) @updatedAt @db.Timestamp(0)
  doctor                    doctors  @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade)
}

model medicines_master {
  id                   Int             @id @default(autoincrement())
  name                 String          @db.VarChar(255)
  normalized_name      String          @unique(map: "uq_medicines_master_normalized_name") @db.VarChar(255)
  status               emr_master_status @default(approved)
  created_by_doctor_id Int?
  usage_count          Int             @default(0)
  type                 String?         @db.VarChar(100)
  strength             String?         @db.VarChar(100)
  salt_composition     String?         @db.VarChar(255)
  company              String?         @db.VarChar(255)
  created_at           DateTime        @default(now()) @db.Timestamp(0)
  updated_at           DateTime        @default(now()) @updatedAt @db.Timestamp(0)
  created_by_doctor    doctors?        @relation("emr_medicines_master_created_by", fields: [created_by_doctor_id], references: [doctor_id], onDelete: SetNull)
  prescription_medicines prescription_medicines[]

  @@index([name], map: "idx_medicines_master_name")
  @@index([status], map: "idx_medicines_master_status")
  @@index([created_by_doctor_id], map: "idx_medicines_master_created_by_doctor_id")
}

model complaints_master {
  id                   Int               @id @default(autoincrement())
  name                 String            @db.VarChar(255)
  normalized_name      String            @unique(map: "uq_complaints_master_normalized_name") @db.VarChar(255)
  status               emr_master_status @default(approved)
  created_by_doctor_id Int?
  usage_count          Int               @default(0)
  created_at           DateTime          @default(now()) @db.Timestamp(0)
  updated_at           DateTime          @default(now()) @updatedAt @db.Timestamp(0)
